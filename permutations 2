public class Solution {
    public IList<IList<int>> PermuteUnique(int[] nums) {
        IList<IList<int>> result = new List<IList<int>>();
        // 1. Sort the array to place duplicates adjacent to each other
        Array.Sort(nums);
        bool[] used = new bool[nums.Length];
        
        Backtrack(nums, new List<int>(), used, result);
        return result;
    }

    private void Backtrack(int[] nums, List<int> current, bool[] used, IList<IList<int>> result) {
        // Base case: if the current path matches the length of nums, we found a unique permutation
        if (current.Count == nums.Length) {
            result.Add(new List<int>(current));
            return;
        }

        for (int i = 0; i < nums.Length; i++) {
            // If the element is already used in the current path, skip it
            if (used[i]) continue;

            // Pruning: skip duplicates. If the previous identical element hasn't been used yet,
            // it means we are trying to start a new branch with a duplicate element, which causes redundancy.
            if (i > 0 && nums[i] == nums[i - 1] && !used[i - 1]) continue;

            // Make choice
            current.Add(nums[i]);
            used[i] = true;

            // Explore
            Backtrack(nums, current, used, result);

            // Undo choice (backtrack)
            current.RemoveAt(current.Count - 1);
            used[i] = false;
        }
    }
}
