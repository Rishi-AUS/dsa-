public class Solution {
    public int NumDistinct(string s, string t) {
        int m = s.Length;
        int n = t.Length;

        // dp[j] stores the number of distinct subsequences of s that match t[0...j-1]
        int[] dp = new int[n + 1];
        
        // Base case: An empty string t can always be formed from any prefix of s in 1 way
        dp[0] = 1;

        // Process each character of s
        for (int i = 1; i <= m; i++) {
            // Iterate backwards to use only 1D array without overwriting previous row values
            for (int j = n; j >= 1; j--) {
                if (s[i - 1] == t[j - 1]) {
                    // Two choices: either match the current character or skip it
                    dp[j] = dp[j] + dp[j - 1];
                }
                // If s[i-1] != t[j-1], dp[j] remains unchanged (same as dp[i-1][j])
            }
        }

        return dp[n];
    }
}
