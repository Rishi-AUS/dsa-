public class Solution {
    public int Jump(int[] nums) {
        int jumps = 0;
        int currentEnd = 0;
        int furthest = 0;
        
        // We stop before the last element because we are guaranteed to reach the end
        for (int i = 0; i < nums.Length - 1; i++) {
            // Update the maximum reach possible from the current index
            furthest = Math.Max(furthest, i + nums[i]);
            
            // If we have reached the end of the current jump's range
            if (i == currentEnd) {
                jumps++;            // We must make another jump
                currentEnd = furthest; // The next jump can take us up to 'furthest'
                
                // If the new boundary already covers or exceeds the destination, we can break early
                if (currentEnd >= nums.Length - 1) {
                    break;
                }
            }
        }
        
        return jumps;
    }
}
