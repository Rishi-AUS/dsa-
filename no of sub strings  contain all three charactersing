#include <string.h>

#define MIN(a, b) ((a) < (b) ? (a) : (b))

int numberOfSubstrings(char* s) {
    int lastPos[3] = {-1, -1, -1}; // Stores last seen index of 'a', 'b', and 'c'
    int count = 0;
    int n = strlen(s);

    for (int i = 0; i < n; i++) {
        // Update the last seen position of the current character
        lastPos[s[i] - 'a'] = i;

        // If we have seen all three characters at least once
        if (lastPos[0] != -1 && lastPos[1] != -1 && lastPos[2] != -1) {
            // Find the character that appeared furthest back
            int minIdx = MIN(lastPos[0], MIN(lastPos[1], lastPos[2]));
            
            // All substrings starting from index 0 to minIdx and ending at i are valid
            count += (minIdx + 1);
        }
    }

    return count;
}
