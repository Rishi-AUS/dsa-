using System;
using System.Collections.Generic;

public class Solution {
    // Memoization dictionary to store calculated states
    private Dictionary<string, bool> memo = new Dictionary<string, bool>();

    public bool IsScramble(string s1, string s2) {
        // Base Cases
        if (s1 == s2) return true;
        if (s1.Length != s2.Length) return false;
        
        // Use a unique key for the state
        string key = s1 + "_" + s2;
        if (memo.ContainsKey(key)) return memo[key];

        // Anagram check: Prune branches where character counts don't match
        int[] count = new int[26];
        for (int i = 0; i < s1.Length; i++) {
            count[s1[i] - 'a']++;
            count[s2[i] - 'a']--;
        }
        for (int i = 0; i < 26; i++) {
            if (count[i] != 0) {
                memo[key] = false;
                return false;
            }
        }

        int n = s1.Length;
        // Try splitting the string at every possible index `k`
        for (int k = 1; k < n; k++) {
            // Case 1: No swap happens at the current split
            // s1 left matches s2 left AND s1 right matches s2 right
            if (IsScramble(s1.Substring(0, k), s2.Substring(0, k)) && 
                IsScramble(s1.Substring(k), s2.Substring(k))) {
                memo[key] = true;
                return true;
            }

            // Case 2: A swap happens at the current split
            // s1 left matches s2 right AND s1 right matches s2 left
            if (IsScramble(s1.Substring(0, k), s2.Substring(n - k)) && 
                IsScramble(s1.Substring(k), s2.Substring(0, n - k))) {
                memo[key] = true;
                return true;
            }
        }

        memo[key] = false;
        return false;
    }
}
